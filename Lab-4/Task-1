class Car {
    String brand;
    String model;
    double price;

    // Constructor
    Car(String b, String m, double p) {
        brand = b;
        model = m;
        price = p;
    }

    void displayCar() {
        System.out.println("Brand: " + brand);
        System.out.println("Model: " + model);
        System.out.println("Price: " + price);
    }

    public static void main(String[] args) {
        Car car1 = new Car("Toyota", "Corolla", 2000000);
        car1.displayCar();
    }
}
