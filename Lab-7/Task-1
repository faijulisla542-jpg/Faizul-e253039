public class Calculator { 
    // Method 1: Add two integers 
    public int add(int a, int b) { 
        return a + b; 
    } 
    // Method 2: Add two doubles (fractions) 
    public double add(double a, double b) { 
        return a + b; 
    } 
    // Method 3: Add three integers 
    public int add(int a, int b, int c) { 
        return a + b + c; 
    } 
    public static void main(String[] args) { 
        Calculator calc = new Calculator(); 
        int result1 = calc.add(5, 10); 
        System.out.println("Sum of two integers: " + result1); 
        double result2 = calc.add(3.5, 2.7); 
        System.out.println("Sum of two doubles: " + result2); 
        int result3 = calc.add(4, 6, 8); 
        System.out.println("Sum of three integers: " + result3); 
    } 
}
